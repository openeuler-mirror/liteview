import("//gn/toolchain/gcc_toolchain.gni")
import("//gn/toolchain/posix/settings.gni")
import("//gn/toolchain/posix/livi_toolchain.gni")

gcc_toolchain("clang_x86") {
  cc = clang_cc
  cxx = clang_cxx
  ld = cxx

  readelf = readelf
  ar = ar
  nm = nm

  toolchain_args = {
    current_cpu = "x86"
    current_os = target_os
    is_clang = true
  }
}

